# ===== Mobile HR (Flutter) =====
# Copy to ".env". Base URL of the NestJS backend API. Pick your run target:
#   - Android emulator:        http://10.0.2.2:3000/api
#   - Physical device (USB):   run `adb reverse tcp:3000 tcp:3000`, then use localhost
#   - Physical device (WiFi):  http://<PC-LAN-IP>:3000/api  e.g. http://192.168.110.54:3000/api
API_BASE_URL=http://localhost:3000/api
